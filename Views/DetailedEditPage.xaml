<Page
    x:Class="ContextMenuManager.Views.DetailedEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:ContextMenuManager.Localization"
    xmlns:vm="using:ContextMenuManager.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Icon="Refresh" Label="{x:Bind loc:Loc.Tr('ToolBar.Refresh')}" Click="Refresh_Click" />
        </CommandBar>

        <ListView Grid.Row="1" ItemsSource="{x:Bind VM.Rules, Mode=OneWay}"
                  SelectionMode="None" Padding="16,4,16,8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,3" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DetailedEditRule">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14,9">
                        <Grid ColumnSpacing="12" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Tip}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind RegPath}" FontSize="10" Opacity="0.5"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{x:Bind RegPath}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{x:Bind IsOn, Mode=TwoWay}"
                                          MinWidth="0" OnContent="" OffContent="" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="2" Text="{x:Bind VM.StatusText, Mode=OneWay}" Padding="16,6" Opacity="0.7" />
    </Grid>
</Page>
