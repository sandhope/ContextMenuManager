<Page
    x:Class="ContextMenuManager.Views.AppSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:ContextMenuManager.Localization">

    <Page.Resources>
        <!-- 设置项卡片：与其余页面统一的圆角卡片风格 -->
        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <!-- 卡片内部布局：文本占满左侧、控件贴靠右侧并垂直居中 -->
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Spacing="6" Padding="16">

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.AutoBackup')}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="{x:Bind VM.AutoBackup, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.ShowFilePath')}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="{x:Bind VM.ShowFilePath, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.HideDisabledItems')}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="{x:Bind VM.HideDisabledItems, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.HideSysStoreItems')}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="{x:Bind VM.HideSysStoreItems, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.ProtectOpenItem')}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="{x:Bind VM.ProtectOpenItem, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.TopMost')}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="{x:Bind VM.TopMost, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.WinXSortable')}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="{x:Bind VM.WinXSortable, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.OpenMoreRegedit')}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="{x:Bind VM.OpenMoreRegedit, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.OpenMoreExplorer')}" />
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsOn="{x:Bind VM.OpenMoreExplorer, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCard}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SettingLabel}" Text="{x:Bind loc:Loc.Tr('Setting.UpdateFrequency')}" />
                    <ComboBox x:Name="FreqCombo" Grid.Column="1" VerticalAlignment="Center" MinWidth="160" SelectionChanged="FreqCombo_SelectionChanged" />
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
