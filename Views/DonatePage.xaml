<Page
    x:Class="ContextMenuManager.Views.DonatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:ContextMenuManager.Localization"
    Loaded="OnLoaded">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16" MaxWidth="680">
            <!-- 中文：展示收款码 -->
            <StackPanel x:Name="ZhPanel" Spacing="16" Visibility="Collapsed">
                <TextBlock x:Name="ZhTitle" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="28" HorizontalAlignment="Center">
                    <StackPanel Spacing="8">
                        <Image x:Name="AlipayImage" Width="220" Height="220" Stretch="Uniform" />
                        <TextBlock x:Name="AlipayLabel" HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Spacing="8">
                        <Image x:Name="WechatImage" Width="220" Height="220" Stretch="Uniform" />
                        <TextBlock x:Name="WechatLabel" HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
                <TextBlock x:Name="ZhTip" TextWrapping="Wrap" Foreground="Gray" />
            </StackPanel>

            <!-- 英文：直接跳转仓库 -->
            <StackPanel x:Name="EnPanel" Spacing="12" Visibility="Collapsed">
                <TextBlock x:Name="EnTip" TextWrapping="Wrap" />
                <HyperlinkButton Content="{x:Bind loc:Loc.Tr('Page.GithubRepo')}" NavigateUri="https://github.com/sandhope/ContextMenuManager" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
