<Page
    x:Class="ContextMenuManager.Views.GuidBlockedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:ContextMenuManager.Localization"
    xmlns:vm="using:ContextMenuManager.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Icon="Refresh" Label="{x:Bind loc:Loc.Tr('ToolBar.Refresh')}" Click="Refresh_Click" />
            <AppBarButton Icon="Locked" Label="{x:Bind loc:Loc.Tr('Page.ApplyLock')}" Click="Apply_Click" />
        </CommandBar>

        <StackPanel Grid.Row="1" Padding="16,8" Spacing="8" Orientation="Horizontal">
            <TextBox Header="{x:Bind loc:Loc.Tr('Page.InputGuid')}" PlaceholderText="{}{xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}"
                     Text="{x:Bind VM.NewGuid, Mode=TwoWay}" Width="360" />
            <Button Content="{x:Bind loc:Loc.Tr('Page.Add')}" Command="{x:Bind VM.AddCommand}" VerticalAlignment="Bottom"
                    Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>

        <Grid Grid.Row="2">
        <ListView x:Name="ItemList" ItemsSource="{x:Bind VM.Items, Mode=OneWay}"
                  SelectionMode="None" Padding="16,4,16,8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,3" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:GuidBlockedItem">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14,9">
                        <Grid ColumnSpacing="12" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE8A5;" FontSize="18" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind DisplayText}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind GuidText}" FontSize="11" Opacity="0.55"
                                           TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind GuidText}" />
                            </StackPanel>
                            <Button Grid.Column="2" Click="Delete_Click"
                                    Background="Transparent" BorderThickness="0" Padding="8"
                                    VerticalAlignment="Center" ToolTipService.ToolTip="{x:Bind loc:Loc.Tr('Page.Delete')}">
                                <FontIcon Glyph="&#xE74D;" FontSize="16" />
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

            <!-- 空状态：无数据时给出明确、友好的占位而非空白列表 -->
            <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="10" MaxWidth="360">
                <FontIcon Glyph="&#xE7C3;" FontSize="40" Opacity="0.35" />
                <TextBlock Text="{x:Bind loc:Loc.Tr('Status.EmptyList')}"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap" Opacity="0.7"
                           Style="{StaticResource BodyTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="3" Padding="16,6" Opacity="0.7" TextWrapping="Wrap">
            <Run Text="{x:Bind VM.StatusText, Mode=OneWay}" />
            <LineBreak />
            <Run Text="{x:Bind loc:Loc.Tr('Page.GuidBlockedTip')}" Foreground="#999999" />
        </TextBlock>
    </Grid>
</Page>
