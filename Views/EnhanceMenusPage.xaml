<Page
    x:Class="ContextMenuManager.Views.EnhanceMenusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:ContextMenuManager.Localization"
    xmlns:vm="using:ContextMenuManager.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Icon="Refresh" Label="{x:Bind loc:Loc.Tr('ToolBar.Refresh')}" Click="Refresh_Click" />
        </CommandBar>

        <StackPanel Grid.Row="1" Padding="16,8" Spacing="8">
            <ComboBox Header="{x:Bind loc:Loc.Tr('Page.TargetScene')}"
                      ItemsSource="{x:Bind VM.Scenes}"
                      DisplayMemberPath="Name"
                      SelectedItem="{x:Bind VM.SelectedScene, Mode=TwoWay}"
                      MinWidth="260" />
            <TextBlock Text="{x:Bind loc:Loc.Tr('Page.EnhanceTip')}" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>

        <ListView Grid.Row="2" ItemsSource="{x:Bind VM.Items, Mode=OneWay}" SelectionMode="None" Padding="16,4,16,8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,3" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:EnhancePresetItem">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14,9">
                        <Grid ColumnSpacing="12" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="{x:Bind Glyph}" FontSize="18" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Text}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind Def.SceneName}" FontSize="11" Opacity="0.55" TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="2" IsOn="{x:Bind IsPresent, Mode=OneWay}"
                                          Toggled="Preset_Toggled"
                                          MinWidth="0" OnContent="" OffContent=""
                                          VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="3" Text="{x:Bind VM.StatusText, Mode=OneWay}" Padding="16,6" Opacity="0.7" />
    </Grid>
</Page>
