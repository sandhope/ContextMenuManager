<Page
    x:Class="ContextMenuManager.Views.ShellListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:ContextMenuManager.Localization"
    xmlns:vm="using:ContextMenuManager.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 头部行：左侧场景说明与右侧操作按钮同处一行，填补标题下方原本空缺的左侧区域，避免大片空白 -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- 场景说明：让用户明确当前页面在管理"哪一类"右键菜单 -->
            <TextBlock x:Name="SceneDescription" Grid.Column="0" Visibility="Collapsed"
                       VerticalAlignment="Center" Margin="16,0,8,0" Opacity="0.7" FontSize="12.5"
                       TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" />
            <CommandBar Grid.Column="1" DefaultLabelPosition="Right" Background="Transparent">
                <AppBarButton Icon="Add" Label="{x:Bind loc:Loc.Tr('Page.New')}" Click="AddButton_Click" />
                <AppBarButton Icon="Refresh" Label="{x:Bind loc:Loc.Tr('ToolBar.Refresh')}" Click="RefreshButton_Click" />
            </CommandBar>
        </Grid>

        <Grid x:Name="InputBar" Grid.Row="1" Visibility="Collapsed"
              Padding="16,4,16,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="InputLabel" Grid.Column="0" VerticalAlignment="Center" />
            <TextBox x:Name="InputBox" Grid.Column="1" VerticalAlignment="Center"
                     KeyDown="InputBox_KeyDown" />
            <Button x:Name="BrowseFileButton" Grid.Column="2" Visibility="Collapsed"
                    Click="BrowseFileButton_Click" />
            <Button x:Name="BrowseFolderButton" Grid.Column="3" Visibility="Collapsed"
                    Click="BrowseFolderButton_Click" />
            <Button x:Name="ApplyButton" Grid.Column="4"
                    Style="{StaticResource AccentButtonStyle}" Click="ApplyButton_Click" />
        </Grid>

        <Grid Grid.Row="2">
            <ListView x:Name="ItemList"
                      ItemsSource="{x:Bind VM.Items, Mode=OneWay}"
                      SelectionMode="None"
                      Padding="16,4,16,12">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,3" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:MenuItemViewModel">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14,8">
                            <Grid ColumnSpacing="10" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="{x:Bind IconGlyph}" FontSize="18"
                                          VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Text}" FontSize="14" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind RegPath}" FontSize="11" Opacity="0.55"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTipService.ToolTip="{x:Bind RegPath}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="2" IsOn="{x:Bind IsVisible, Mode=TwoWay}"
                                              IsEnabled="{x:Bind SupportsVisibilityToggle}"
                                              MinWidth="0" OnContent="" OffContent=""
                                              VerticalAlignment="Center"
                                              ToolTipService.ToolTip="{x:Bind loc:Loc.Tr('Setting.HideDisabledItems')}" />
                                <Button Grid.Column="3" Click="EditButton_Click"
                                        Background="Transparent" BorderThickness="0" Padding="8"
                                        VerticalAlignment="Center" MinWidth="40"
                                        ToolTipService.ToolTip="{x:Bind loc:Loc.Tr('Menu.Edit')}">
                                    <FontIcon Glyph="&#xE70F;" FontSize="16" />
                                </Button>
                                <Button Grid.Column="4"
                                        Background="Transparent" BorderThickness="0" Padding="8"
                                        VerticalAlignment="Center" MinWidth="40"
                                        ToolTipService.ToolTip="{x:Bind loc:Loc.Tr('Menu.OtherAttributes')}">
                                    <FontIcon Glyph="&#xE712;" FontSize="16" />
                                    <Button.Flyout>
                                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                                            <MenuFlyoutItem Text="{x:Bind loc:Loc.Tr('Menu.RegistryLocation')}"
                                                            Command="{x:Bind RegLocationCommand}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE71D;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="{x:Bind loc:Loc.Tr('Menu.FileLocation')}"
                                                            Command="{x:Bind FileLocationCommand}"
                                                            IsEnabled="{x:Bind HasFilePath}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE838;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="{x:Bind loc:Loc.Tr('Menu.CopyGuid')}"
                                                            Command="{x:Bind CopyGuidCommand}"
                                                            IsEnabled="{x:Bind HasGuid}">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE8C8;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="{x:Bind loc:Loc.Tr('Menu.Delete')}"
                                                            Tag="{x:Bind}"
                                                            Click="DeleteMenuFlyoutItem_Click">
                                                <MenuFlyoutItem.Icon>
                                                    <FontIcon Glyph="&#xE74D;" />
                                                </MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 空状态：无数据时给出明确、友好的占位而非空白列表 -->
            <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="10" MaxWidth="360">
                <FontIcon Glyph="&#xE7C3;" FontSize="40" Opacity="0.35" />
                <TextBlock x:Name="EmptyStateText" HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap" Opacity="0.7"
                           Style="{StaticResource BodyTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="3" Text="{x:Bind VM.StatusText, Mode=OneWay}" Padding="16,6" Opacity="0.7" />
    </Grid>
</Page>
