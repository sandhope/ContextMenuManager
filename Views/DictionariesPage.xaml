<Page
    x:Class="ContextMenuManager.Views.DictionariesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:ContextMenuManager.Localization"
    xmlns:vm="using:ContextMenuManager.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 头部行：左侧说明与右侧操作按钮同处一行，避免标题下方左侧出现大片空白 -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{x:Bind VM.Description, Mode=OneTime}" TextWrapping="Wrap"
                       MaxWidth="760" HorizontalAlignment="Left" VerticalAlignment="Center"
                       FontSize="13" Opacity="0.8" Margin="16,0,8,0" />
            <CommandBar Grid.Column="1" DefaultLabelPosition="Right">
                <AppBarButton Icon="Folder" Label="{x:Bind loc:Loc.Tr('Page.OpenFolder')}" Click="OpenFolderButton_Click" />
                <AppBarButton Icon="Refresh" Label="{x:Bind loc:Loc.Tr('ToolBar.Refresh')}" Click="RefreshButton_Click" />
            </CommandBar>
        </Grid>

        <ListView Grid.Row="1" ItemsSource="{x:Bind VM.Items, Mode=OneWay}"
                  SelectionMode="None" Padding="16,0,16,8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,3" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DictionaryEntry">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14,9">
                        <Grid ColumnSpacing="12" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="{x:Bind IconGlyph}" FontSize="18" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Detail}" FontSize="12" Opacity="0.65"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Border Grid.Column="2" Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                                    CornerRadius="10" Padding="10,3" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Category}" FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="2" Text="{x:Bind VM.StatusText, Mode=OneWay}" Padding="16,6" Opacity="0.7" />
    </Grid>
</Page>
